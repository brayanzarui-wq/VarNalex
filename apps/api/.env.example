# ---------------------------------------------------------------------------
# VarNalex API — variables de entorno
# Copia este archivo a `.env` y completa los valores reales.
# NINGÚN valor real (secretos, tokens, credenciales) debe commitearse.
# ---------------------------------------------------------------------------

# --- Base de datos (Neon / PostgreSQL) ---
# Cadena de conexión de Neon. Ejemplo:
# postgresql://usuario:password@ep-xxx.us-east-2.aws.neon.tech/varnalex?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Autenticación (JWT) ---
# Secretos largos y aleatorios. Genera con: openssl rand -base64 48
JWT_ACCESS_SECRET="CAMBIAR_secreto_access_largo_y_aleatorio"
JWT_REFRESH_SECRET="CAMBIAR_secreto_refresh_largo_y_aleatorio"
# Access token expira en 24h (sección 7 del contexto).
JWT_ACCESS_EXPIRES_IN="24h"
# Refresh token rotativo, vida útil en días.
JWT_REFRESH_EXPIRES_IN_DAYS="30"

# --- Cifrado de tokens de Connection (accessToken/refreshToken de terceros) ---
# Clave de 32 bytes en hex (64 caracteres). Genera con: openssl rand -hex 32
CONNECTION_ENCRYPTION_KEY="CAMBIAR_clave_hex_de_64_caracteres_32_bytes"

# --- Servidor ---
PORT="3000"
NODE_ENV="development"
# Origen del frontend permitido por CORS.
CORS_ORIGIN="http://localhost:3001"

# --- Integraciones de terceros (dejar vacío hasta tener credenciales) ---
# Meta Ads (Marketing API)
META_APP_ID=""
META_APP_SECRET=""
# Google Ads / Google Analytics 4
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_ADS_DEVELOPER_TOKEN=""

# --- Email transaccional (Resend) ---
RESEND_API_KEY=""

# --- Storage de archivos (Cloudflare R2) ---
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""

# --- Monitoreo (Sentry) ---
SENTRY_DSN=""
